{
  "firestore": {
    "rules": "firestore.rules",
    "ignore": [
      "firebase-debug.log",
      "firebase-debug.*.log",
      "*_node_modules",
      "**/node_modules/**"
    ]
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  },
  "emulators": {
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8080
    },
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": true
    }
  }
}