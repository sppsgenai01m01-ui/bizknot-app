rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() { return request.auth != null; }
    function isNotSuspended() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status != 'SUSPENDED'; }
    function isAdmin() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permission == 'admin'; }

    match /users/{userId} {
      allow create: if isAuthenticated() && request.auth.uid == userId && !exists(/databases/$(database)/documents/users/$(userId));
      allow read: if isAuthenticated() && isNotSuspended() && (request.auth.uid == userId || isAdmin());
      allow update, delete: if isAuthenticated() && isNotSuspended() && isAdmin();
    }

    function isValidCard() {
      let data = request.resource.data;
      return data.keys().hasAll(['ownerId', 'companyName'])
          && data.ownerId == request.auth.uid
          && data.companyName is string
          && data.companyName.size() > 0;
    }

    match /businessCards/{cardId} {
      function isOwner() {
        return request.auth.uid == resource.data.ownerId || request.auth.uid == resource.data.userId;
      }

      allow create: if isAuthenticated() && isNotSuspended() && isValidCard();
      
      // 修正: deletedAtが存在しない場合の Nullエラー を防ぐための安全な書き方に変更
      allow read: if isAuthenticated() && isNotSuspended() && (isOwner() || isAdmin()) && (!('deletedAt' in resource.data) || resource.data.deletedAt == null || isAdmin());
      
      allow update: if isAuthenticated() && isNotSuspended() 
                    && (isOwner() || isAdmin())
                    && isValidCard()
                    && (!('deletedAt' in request.resource.data) || request.resource.data.deletedAt == resource.data.deletedAt || isAdmin());
                    
      allow delete: if isAuthenticated() && isNotSuspended() && (isOwner() || isAdmin());
    }

    match /auditLogs/{logId} {
      allow create: if isAuthenticated() && isNotSuspended();
      allow read, list: if isAuthenticated() && isNotSuspended() && isAdmin();
      allow update, delete: if false; 
    }
  }
}
